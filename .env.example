# ─── Copier ce fichier en .env et renseigner les valeurs ───
# cp .env.example .env

# Clé API Resend → https://resend.com/api-keys
# (la même clé que sur ton ancien site, ou une nouvelle clé « Production »)
RESEND_API_KEY=re_51arX7vy_PNnUYXPxNxDkVVXr5iYAezRM

# Expéditeur — doit utiliser un domaine VÉRIFIÉ dans Resend (Domains)
# Si erreur à l'envoi : tester d'abord avec (compte Resend gratuit) :
# RESEND_FROM=onboarding@resend.dev
# Puis, domaine OK :
RESEND_FROM=Maxime Farineau <contact@maximefarineau.com>

# Afficher le détail Resend dans le formulaire (debug Railway) : true / false
# CONTACT_EXPOSE_ERRORS=true

# Destinataire des messages du formulaire
CONTACT_TO=contact@maximefarineau.com

# URL du site (CORS) — sans slash final (Railway + domaine OVH)
SITE_URL=https://maximefarineau.com

# Railway définit PORT automatiquement — ne pas le mettre dans .env local sauf test

# Port du serveur local (npm run dev)
PORT=3001
